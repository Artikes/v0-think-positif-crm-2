    "status_colors": {
      "success": "text-green-600 bg-green-100 dark:bg-green-900/30 dark:text-green-400",
      "warning": "text-orange-600 bg-orange-100 dark:bg-orange-900/30 dark:text-orange-400",
      "error": "text-red-600 bg-red-100 dark:bg-red-900/30 dark:text-red-400",
      "info": "text-blue-600 bg-blue-100 dark:bg-blue-900/30 dark:text-blue-400",
      "high_potential": "text-purple-600 bg-purple-100 dark:bg-purple-900/30 dark:text-purple-400"
    }
  },
  "layout_grid": {
    "dashboard_mode": "Bento Grid Mode B (High Density)",
    "rules": [
      "Use 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4' for main dashboard.",
      "Gap should be 'gap-4' or 'gap-6'.",
      "Summary cards (KPIs) span 1 column.",
      "Main charts span 2 or 3 columns.",
      "Recent activity lists span 1 column but 2 rows (vertical)."
    ]
  },
  "components": {
    "sidebar": {
      "style": "Fixed, full height, border-r.",
      "classes": "w-64 h-screen fixed left-0 top-0 border-r bg-card/50 backdrop-blur-xl z-50 hidden lg:block",
      "active_item": "bg-primary/10 text-primary font-medium"
    },
    "cards": {
      "style": "Clean, minimal, 1px border.",
      "classes": "rounded-lg border bg-card text-card-foreground shadow-sm hover:shadow-md transition-shadow duration-200"
    },
    "buttons": {
      "style": "Pill or Slightly Rounded.",
      "primary": "rounded-md bg-primary text-primary-foreground hover:bg-primary/90 shadow h-10 px-4 py-2",
      "ghost": "rounded-md hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2"
    },
    "tables": {
      "style": "Clean rows, sticky header.",
      "classes": "w-full caption-bottom text-sm",
      "header_row": "border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted",
      "cell": "p-4 align-middle [&:has([role=checkbox])]:pr-0"
    }
  },
  "spacing_and_sizing": {
    "padding_standard": "p-6 md:p-8",
    "container_max_width": "max-w-7xl mx-auto",
    "border_radius": {
      "sm": "rounded-sm",
      "md": "rounded-md",
      "lg": "rounded-lg",
      "full": "rounded-full"
    }
  },
  "motion": {
    "default_transition": "transition-all duration-200 ease-in-out",
    "hover_lift": "hover:-translate-y-0.5 hover:shadow-lg",
    "page_enter": {
      "initial": { "opacity": 0, "y": 10 },
      "animate": { "opacity": 1, "y": 0 },
      "exit": { "opacity": 0, "y": -10 }
    }
  },
