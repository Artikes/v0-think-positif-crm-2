{
  "project_name": "CRM & Talent Management Platform",
  "design_philosophy": {
    "identity": "E1 Anti-AI Designer",
    "core_concept": "French Rationalism meets Modern SaaS. Precision, Clarity, and Hierarchy.",
    "emotional_tone": "Professional, Efficient, Trustworthy, Dynamic.",
    "theme_strategy": "Swiss & High-Contrast (Archetype 4) adapted for Data Density (Archetype 2)."
  },
  "typography": {
    "font_family": {
      "headings": "\"Plus Jakarta Sans\", sans-serif",
      "body": "\"Inter\", sans-serif",
      "mono": "\"JetBrains Mono\", monospace"
    },
    "imports": [
      "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap"
    ],
    "scale": {
      "h1": "text-4xl md:text-5xl font-bold tracking-tight",
      "h2": "text-3xl font-semibold tracking-tight",
      "h3": "text-2xl font-semibold tracking-tight",
      "h4": "text-xl font-semibold tracking-tight",
      "body": "text-sm md:text-base font-normal leading-relaxed",
      "small": "text-xs font-medium text-muted-foreground",
      "label": "text-xs font-semibold uppercase tracking-wider text-muted-foreground"
    },
    "rules": [
      "Headings must use Plus Jakarta Sans.",
      "Body text must use Inter.",
      "Never use Inter for H1/H2.",
      "Use 'tracking-tight' for all headings larger than 24px."
    ]
  },
