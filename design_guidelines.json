  "accessibility": {
    "contrast_check": "Ensure 4.5:1 ratio for text.",
    "interactive_elements": "Must have :focus-visible styles (ring-2 ring-ring ring-offset-2).",
    "screen_readers": "Use visually-hidden labels for icon-only buttons."
  },
  "french_language_rules": {
    "text_expansion": "Accommodate 20-30% longer text than English.",
    "date_format": "dd/MM/yyyy",
    "currency": "EUR (1 234,56 €)",
    "capitalization": "French sentence case rules (mostly lowercase except first letter)."
  },
  "universal_guidelines": [
    "Do NOT use gradients for main backgrounds.",
    "Use 'sonner' for toasts.",
    "Use 'lucide-react' for icons.",
    "All interactive elements MUST have data-testid.",
    "Do NOT use HTML <select>, use Shadcn <Select>.",
    "Do NOT use HTML <input type='date'>, use Shadcn <Calendar> with Popover.",
    "Avoid centering text in dashboards; left-align is standard for readability.",
    "Add transition-all duration-200 to all interactive elements."
  ],
  "instructions_to_main_agent": [
    "Update /app/frontend/src/index.css with the provided HSL variables.",
    "Update /app/frontend/public/index.html to include the Google Fonts.",
    "Use 'Plus Jakarta Sans' for all headings (h1-h6) and 'Inter' for body.",
    "Implement the Layout Wrapper with a Sidebar that collapses on mobile.",
    "Ensure the Theme Toggle works using 'next-themes'.",
    "Follow the Bento Grid layout for the Dashboard page."
  ]
